# Voltia Monorepo .gitignore

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
.npm
.eslintcache

# --- OS ---
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# --- Environment & Secrets ---
.env
.env.*
!.env.example
.secret
credentials.json
api/error.txt

# --- Architecture & Build ---
dist/
dist-ssr/
build/
coverage/
.turbo/
.vercel/
.next/

# --- Frontend (Vite/React) ---
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/coverage/

# --- API (NestJS/Prisma) ---
api/node_modules/
api/dist/
api/coverage/
api/prisma/*.db
api/prisma/*.db-journal

# --- Docker & Database ---
.docker/
data/
db-data/
mysql-data/
mariadb-data/

# --- IDEs & Editors ---
.vscode/
.idea/
*.swp
*.swo
.project
.settings/
.classpath
